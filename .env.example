# =========================================================================
# 🌐 MACPREP REAL-TIME ENVIRONMENT PRODUCTION CONFIGURATION SECRETS
# =========================================================================

# Application Port (Render load balancers inject this automatically)
PORT=3000

# Supabase Relational Postgres Storage Access Strings
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL_HERE
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# Stripe Live Production API Token Gateways
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE
# Price id used by POST /api/create-checkout-session (the single checkout path)
STRIPE_PRODUCTION_PRICE_ID=YOUR_STRIPE_PRICE_ID_HERE

# Content gating: set to 'true' to serve only SME-approved (status='published')
# questions. Leave false/unset while the bank is still being authored.
SERVE_PUBLISHED_ONLY=false
