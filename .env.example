# =========================================================================
# 🌐 MACPREP ENVIRONMENT CONFIGURATION
# =========================================================================
# Copy to `.env` for local dev, or set these in the Render dashboard for prod.
# In production set NODE_ENV=production — the server then FAILS TO BOOT if any
# required key below is missing, or if a Stripe TEST key is used (so real
# customers are never charged in test mode).

# Set to 'production' on Render. Enables fail-fast config checks.
NODE_ENV=production

# Application Port (Render injects this automatically)
PORT=3000

# --- Supabase (Postgres + Auth) — REQUIRED -------------------------------
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL_HERE
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# --- Stripe (LIVE keys in production) — REQUIRED -------------------------
# STRIPE_SECRET_KEY must be a live key (sk_live_...). An sk_test_ key is
# refused at boot when NODE_ENV=production.
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE
# Price id used by POST /api/create-checkout-session (the single checkout path)
STRIPE_PRODUCTION_PRICE_ID=YOUR_STRIPE_PRICE_ID_HERE
# Set to 'true' to collect sales tax via Stripe Tax (requires tax registrations).
STRIPE_AUTOMATIC_TAX=false

# --- Content gating ------------------------------------------------------
# 'true' (default): the public sees ONLY clinician-approved (status='published')
# questions. Set 'false' ONLY in a private preview env to also serve pending
# (status='sme_review') content. KEEP 'true' IN PRODUCTION.
SERVE_PUBLISHED_ONLY=true
# 'true' would also serve the unreliable legacy filler bank. Leave false.
SERVE_FILLER=false

# --- URLs / security -----------------------------------------------------
# Comma-separated host allowlist used to build reset/checkout return URLs.
ALLOWED_HOSTS=www.macprep.org,macprep.org
# Canonical base URL for links in redirects (e.g. https://www.macprep.org)
PUBLIC_BASE_URL=https://www.macprep.org

# --- Monitoring (optional) ----------------------------------------------
# Server-side Sentry DSN. When set, the backend reports uncaught exceptions,
# unhandled rejections, and Express errors. Unset => error capture is a no-op.
SENTRY_DSN=
# Browser Sentry DSN, exposed to the frontend via /api/config for error capture.
SENTRY_BROWSER_DSN=
