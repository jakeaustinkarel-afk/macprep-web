# =========================================================================
# 🌐 MACPREP ENVIRONMENT CONFIGURATION
# =========================================================================
# Copy to `.env` for local dev, or set these in the Render dashboard for prod.
# In production set NODE_ENV=production — the server then FAILS TO BOOT if any
# required key below is missing, or if a Stripe TEST key is used (so real
# customers are never charged in test mode).

# Set to 'production' on Render. Enables fail-fast config checks.
NODE_ENV=production

# Application Port (Render injects this automatically)
PORT=3000

# --- Supabase (Postgres + Auth) — REQUIRED -------------------------------
SUPABASE_URL=YOUR_SUPABASE_PROJECT_URL_HERE
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY_HERE

# --- Stripe (LIVE keys in production) — REQUIRED -------------------------
# STRIPE_SECRET_KEY must be a live key (sk_live_...). An sk_test_ key is
# refused at boot when NODE_ENV=production.
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET_HERE
# Price id used by POST /api/create-checkout-session (the single checkout path)
STRIPE_PRODUCTION_PRICE_ID=YOUR_STRIPE_PRICE_ID_HERE
# Set to 'true' to collect sales tax via Stripe Tax (requires tax registrations).
STRIPE_AUTOMATIC_TAX=false

# --- Native one-time purchases (required before enabling store checkout) ---
# Both native stores grant the same user_profiles.account_tier='premium'
# entitlement as a web purchase. Keep the product ID identical in App Store
# Connect, Play Console, and the native code.
MOBILE_PREMIUM_PRODUCT_ID=org.macprep.app.full_access
MOBILE_APP_BUNDLE_ID=org.macprep.app
# Apple App Store Server API credentials. APPLE_IAP_PRIVATE_KEY may contain
# literal \n escapes. APPLE_IAP_ROOT_CERTIFICATES_BASE64 is a JSON array of
# base64-encoded DER Apple root certificates. APPLE_IAP_APP_ID is the numeric
# App Store Connect Apple ID and is required for production verification.
APPLE_IAP_ISSUER_ID=
APPLE_IAP_KEY_ID=
APPLE_IAP_PRIVATE_KEY=
APPLE_IAP_APP_ID=
APPLE_IAP_ROOT_CERTIFICATES_BASE64=[]
# A Google Cloud service-account JSON document with Android Publisher API
# access. The server accepts either the raw JSON or a base64-encoded document.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# --- Content gating ------------------------------------------------------
# 'true' (default): the public sees ONLY clinician-approved (status='published')
# questions. Set 'false' ONLY in a private preview env to also serve pending
# (status='sme_review') content. KEEP 'true' IN PRODUCTION.
SERVE_PUBLISHED_ONLY=true
# 'true' would also serve the unreliable legacy filler bank. Leave false.
SERVE_FILLER=false

# --- URLs / security -----------------------------------------------------
# Comma-separated host allowlist used to build reset/checkout return URLs.
ALLOWED_HOSTS=www.macprep.org,macprep.org
# Canonical base URL for links in redirects (e.g. https://www.macprep.org)
PUBLIC_BASE_URL=https://www.macprep.org

# --- Monitoring (optional) ----------------------------------------------
# Server-side Sentry DSN. When set, the backend reports uncaught exceptions,
# unhandled rejections, and Express errors. Unset => error capture is a no-op.
SENTRY_DSN=
# Browser Sentry DSN, exposed to the frontend via /api/config for error capture.
SENTRY_BROWSER_DSN=

# --- Web Push / PWA notifications (optional) -----------------------------
# The ENTIRE push pipeline (service worker, subscribe flow, daily reminder
# scheduler, admin test) is code-complete but stays DORMANT until BOTH keys
# below are set — PUSH_ENABLED = !!(VAPID_PUBLIC_KEY && VAPID_PRIVATE_KEY).
# Generate the pair yourself (keeps the private key off anyone else's machine):
#     npx web-push generate-vapid-keys
# Then paste the two values here (local) or into the Render dashboard (prod).
# The private key is a SECRET — never commit it. Rotating it invalidates every
# existing browser subscription (users just re-enable reminders).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URI sent to push services per the VAPID spec (mailto: or https:).
VAPID_SUBJECT=mailto:support@macprep.org
