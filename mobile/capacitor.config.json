{
  "appId": "org.macprep.app",
  "appName": "MACPrep",
  "webDir": "www",
  "server": {
    "url": "https://www.macprep.org",
    "cleartext": false
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#146A4A",
      "showSpinner": false
    }
  },
  "ios": {
    "contentInset": "always",
    "limitsNavigationsToAppBoundDomains": false
  },
  "android": {
    "allowMixedContent": false
  }
}
